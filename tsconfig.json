{
  "compileOnSave": false,
  "compilerOptions": {
    "module": "esnext",
    "esModuleInterop": true,
    "target": "esnext",
    "lib": [
      "es2017",
      "es2019",
      "ES2022",
      "ES2023.Array",
    ],
    "types": [
      "vitest/globals",
      "aws-lambda",
      "node",
    ],
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "sourceMap": false,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "paths": {
      "@household/api/*": [
        "./api/src/*"
      ],
      "@household/shared/*": [
        "./shared/src/*"
      ],
      "@household/test/*": [
        "./test/src/*"
      ]
    }
  },
  "include": [
    "api/src",
    "shared/src",
    "test"
  ]
}