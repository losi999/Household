{
  "compileOnSave": false,
  "compilerOptions": {
    "module": "esnext",
    "esModuleInterop": true,
    "isolatedModules": false,
    "strict": false,
    "noEmit": true,
    "target": "es2022",
    "lib": [
      "es2017",
      "es2019",
      "ES2022",
      "dom"
    ],
    "types": [
      "cypress",
      "node"
    ],
    "noImplicitAny": true,
    "sourceMap": false,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "paths": {
      "@household/test/*": [
        "./src/*"
      ],
      "@household/shared/*": [
        "../shared/src/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}