{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "yarn"
  },
  "newProjectRoot": "projects",
  "projects": {
    "hairdressing": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/hairdressing",
      "sourceRoot": "projects/hairdressing/src",
      "prefix": "hairdressing",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "../dist/hairdressing",
            "browser": "projects/hairdressing/src/main.ts",
            "tsConfig": "projects/hairdressing/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/hairdressing/public"
              }
            ],
            "styles": [
              "projects/hairdressing/src/styles.scss"
            ]
          },
          "configurations": {
            "PROD": {
              "fileReplacements": [
                {
                  "replace": "projects/hairdressing/src/environments/environment.ts",
                  "with": "projects/hairdressing/src/environments/environment.PROD.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "2MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "DEV": {
              "fileReplacements": [
                {
                  "replace": "projects/hairdressing/src/environments/environment.ts",
                  "with": "projects/hairdressing/src/environments/environment.DEV.ts"
                }
              ],
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "LOCAL": {
              "fileReplacements": [
                {
                  "replace": "projects/hairdressing/src/environments/environment.ts",
                  "with": "projects/hairdressing/src/environments/environment.LOCAL.ts"
                }
              ],
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "PROD"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "LOCAL": {
              "buildTarget": "hairdressing:build:LOCAL"
            },
            "PROD": {
              "buildTarget": "hairdressing:build:PROD"
            }
          },
          "defaultConfiguration": "LOCAL"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    },
    "shared": {
      "projectType": "library",
      "root": "projects/shared",
      "sourceRoot": "projects/shared/src",
      "prefix": "shared",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/shared/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/shared/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/shared/tsconfig.spec.json"
          }
        }
      }
    }
  }
}