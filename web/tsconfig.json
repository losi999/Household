{
  "compileOnSave": false,
  "compilerOptions": {
    "sourceMap": true,
    "esModuleInterop": true,
    "declaration": false,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "strict": false,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "ES2022",
    "types": [
      "jasmine"
    ],
    "lib": [
      "es2019",
      "es2018",
      "ES2023.Array",
      "dom"
    ],
    "paths": {
      "@household/shared/*": [
        "../shared/src/*"
      ],
      "@household/web/*": [
        "./src/*"
      ]
    },
    "useDefineForClassFields": false
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false
  }
}