{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "esModuleInterop": true,
    "declaration": false,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2023",
    "module": "preserve",
    "lib": [
      "es2018",
      "ES2023.Array",
      "dom"
    ],
    "baseUrl": "./",
    "paths": {
      "@household/shared/*": [
        "../shared/src/*"
      ],
      "@household/web/*": [
        "./src/*"
      ]
    },
    "useDefineForClassFields": false
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ],
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false
  }
}